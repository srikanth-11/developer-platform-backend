# ---- Application ----
NODE_ENV=development
# 3000/3001 are used by other local apps on this machine; 3333 is free.
PORT=3333
GLOBAL_PREFIX=api

# ---- PostgreSQL ----
DB_HOST=localhost
# Host port mapped in docker-compose.yml. A native Windows PostgreSQL occupies
# 5432/5433, so we use 55432 for our container.
DB_PORT=55432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=devplatform
# Auto-create tables from entities. Keep `true` for now (learning/dev only).
# PRODUCTION: leave true for the FIRST deploy to create the schema on an empty
# RDS database, then set to false (no migrations exist; synchronize can drop columns).
DB_SYNCHRONIZE=true
DB_LOGGING=true
# PRODUCTION (AWS RDS): set DB_SSL=true and paste the RDS CA bundle PEM into
# DB_SSL_CA so the certificate is verified. Leave both unset for local dev.
DB_SSL=false
DB_SSL_CA=

# ---- Redis ----
REDIS_HOST=localhost
# Host 56379 mapped in docker-compose.yml (lower Redis ports already taken).
REDIS_PORT=56379
# PRODUCTION (AWS ElastiCache): set REDIS_PASSWORD to the AUTH token and
# REDIS_TLS=true if in-transit encryption is enabled on the cluster.
REDIS_PASSWORD=
REDIS_TLS=false

# ---- JWT ----
# Use a long, random value in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1d

# ---- Security ----
# Comma-separated allowed CORS origins, or * for any (dev only).
CORS_ORIGINS=*
# Brute-force throttle on auth routes (login/register): N requests per window.
AUTH_THROTTLE_TTL_MS=60000
AUTH_THROTTLE_LIMIT=15
# Max request body size.
BODY_LIMIT=1mb

# ---- Stripe (optional) ----
# Without a secret key, billing runs in metering-only mode (no real charges).
# Get a TEST key from https://dashboard.stripe.com/test/apikeys (starts sk_test_).
FRONTEND_URL=http://localhost:5173
STRIPE_SECRET_KEY=
# From `stripe listen` (CLI) or the dashboard webhook config (starts whsec_).
STRIPE_WEBHOOK_SECRET=
