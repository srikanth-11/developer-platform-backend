# Reference of the env the backend expects in production (free stack:
# Render + Neon + Render Key Value). On Render you set these in the dashboard /
# render.yaml — you don't deploy this file. Shown here so you can see the picture
# or run the container manually.

NODE_ENV=production
PORT=3333
GLOBAL_PREFIX=api

# ---- PostgreSQL (Neon) ----
# Use Neon's POOLED connection string (host contains "-pooler"). SSL required;
# Neon uses a publicly-trusted CA so no custom DB_SSL_CA is needed.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/devplatform
DB_SSL=true
# true ONLY for the first boot (creates the schema on the empty DB), then false.
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ---- Redis (Render Key Value) ----
# Render auto-injects this via render.yaml. For Upstash instead, paste its
# rediss:// URL here (TLS is enabled automatically by the rediss scheme).
REDIS_URL=redis://red-xxxxx:6379

# ---- JWT ----
JWT_SECRET=<48-char-random>   # Render can generate this automatically
JWT_EXPIRES_IN=1d

# ---- Security ----
CORS_ORIGINS=https://your-app.vercel.app
AUTH_THROTTLE_TTL_MS=60000
AUTH_THROTTLE_LIMIT=15
BODY_LIMIT=1mb

# ---- Stripe ----
FRONTEND_URL=https://your-app.vercel.app
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx   # set after creating the webhook
